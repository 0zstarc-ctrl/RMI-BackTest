{
  "name": "rmi-backtest-backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "sync:candles:initial": "tsx src/jobs/syncInitialCandles.ts",
    "verify:ops": "tsx src/scripts/verifyOps.ts",
    "verify:candles": "tsx src/scripts/verifyCandles.ts"
  },
  "dependencies": {
    "@fastify/cors": "10.0.2",
    "@prisma/client": "6.19.0",
    "dotenv": "16.4.7",
    "fastify": "5.2.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "prisma": "6.19.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
